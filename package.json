{
  "name": "ksschoerke",
  "version": "1.0.0",
  "description": "The website for Künstlersekretariat Schoerke, built with Payload CMS and Next.js.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm generate:search-index && cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "format": "oxfmt --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:media": "tsx scripts/utils/regenerateMediaSizes.ts",
    "generate:search-index": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/reindexSearch.ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "oxlint --config oxlint.config.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:artists": "payload run scripts/wordpress/migrateArtists.ts",
    "migrate:employees": "payload run scripts/wordpress/migrateEmployees.ts",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:media": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/wordpress/migrateMedia.js",
    "migrate:discography": "tsx scripts/migrateDiscographyToRecordings.ts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dump": "tsx scripts/db/dumpCollection.ts",
    "dump:artists": "pnpm dump artists",
    "dump:employees": "pnpm dump employees",
    "dump:recordings": "pnpm dump recordings"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@libsql/client": "^0.17.2",
    "@payloadcms/db-sqlite": "^3.83.0",
    "@payloadcms/email-resend": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/payload-cloud": "^3.83.0",
    "@payloadcms/plugin-search": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-s3": "^3.83.0",
    "@payloadcms/storage-vercel-blob": "^3.83.0",
    "@payloadcms/translations": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.0.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^5.7.1",
    "graphql": "^16.13.2",
    "kbar": "0.1.0-beta.48",
    "libsql": "^0.5.29",
    "lodash": "^4.18.1",
    "lucide-react": "^0.577.0",
    "mime": "^4.0.7",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "payload": "^3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^6.12.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.0",
      "brace-expansion": ">=1.1.13",
      "nodemailer": ">=8.0.5",
      "esbuild": ">=0.25.0",
      "diff": ">=4.0.4"
    }
  }
}
