{
  "name": "ksschoerke",
  "version": "1.0.0",
  "description": "The website for Künstlersekretariat Schoerke, built with Payload CMS and Next.js.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .git-hooks",
    "build": "pnpm generate:search-index && cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "format": "oxfmt --write .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:media": "tsx scripts/utils/regenerateMediaSizes.ts",
    "generate:search-index": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/reindexSearch.ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "oxlint --config oxlint.config.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "build:posts-dataset": "tsx scripts/wordpress/buildPostsDataset.ts",
    "migrate:artists": "payload run scripts/wordpress/migrateArtists.ts",
    "migrate:employees": "payload run scripts/wordpress/migrateEmployees.ts",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:media": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/wordpress/migrateMedia.js",
    "migrate:discography": "tsx scripts/migrateDiscographyToRecordings.ts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dump": "tsx scripts/db/dumpCollection.ts",
    "dump:artists": "pnpm dump artists",
    "dump:employees": "pnpm dump employees",
    "dump:recordings": "pnpm dump recordings"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@libsql/client": "^0.17.4",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/payload-cloud": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@vercel/blob": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^5.9.2",
    "graphql": "^16.14.2",
    "kbar": "0.1.0-beta.48",
    "libsql": "^0.5.29",
    "lodash": "^4.18.1",
    "lucide-react": "1.21.0",
    "mime": "^4.1.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "payload": "3.84.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "brace-expansion": ">=1.1.13",
      "diff": ">=4.0.4",
      "dompurify": ">=3.4.0",
      "esbuild": ">=0.25.0",
      "fast-uri": ">=3.1.2",
      "js-yaml": ">=4.2.0",
      "nodemailer": ">=8.0.5",
      "undici": ">=7.28.0",
      "uuid": ">=11.1.1",
      "ws": ">=8.21.0"
    }
  }
}
